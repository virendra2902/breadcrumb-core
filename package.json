{
  "name": "breadcrumb-core",
  "version": "3.0.1",
  "description": "Zero-config breadcrumbs from your route config. Progressive loading, custom matchers, i18n, collapsible overflow, and adapters for React Router, Next.js, and TanStack Router.",
  "author": "virendra2902 <https://github.com/virendra2902>",
  "license": "MIT",
  "homepage": "https://virendra2902.github.io/breadcrumb-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/virendra2902/breadcrumb-core.git"
  },
  "bugs": {
    "url": "https://github.com/virendra2902/breadcrumb-core/issues"
  },
  "keywords": [
    "breadcrumb", "breadcrumb-core", "react", "react-router", "nextjs",
    "tanstack-router", "navigation", "seo", "json-ld", "schema-org",
    "headless", "typescript", "i18n", "progressive-loading",
    "collapsible", "wildcard-routes", "custom-matcher"
  ],
  "main": "./dist/core/index.js",
  "module": "./dist/core/index.mjs",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./react-router": {
      "types": "./dist/react-router/index.d.ts",
      "import": "./dist/react-router/index.mjs",
      "require": "./dist/react-router/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.mjs",
      "require": "./dist/next/index.js"
    },
    "./tanstack-router": {
      "types": "./dist/tanstack-router/index.d.ts",
      "import": "./dist/tanstack-router/index.mjs",
      "require": "./dist/tanstack-router/index.js"
    },
    "./headless": {
      "types": "./dist/headless/index.d.ts",
      "import": "./dist/headless/index.mjs",
      "require": "./dist/headless/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.mjs",
      "require": "./dist/ui/index.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "sideEffects": false
}
