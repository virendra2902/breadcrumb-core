{
    "compilerOptions": {
      "target": "ES2018",
      "module": "CommonJS",
      "moduleResolution": "node",
      "lib": ["ES2018", "DOM"],
      "jsx": "react-jsx",
      "jsxImportSource": "react",
      "strict": true,
      "skipLibCheck": true,
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "types": ["react", "react-dom", "node"],
      "outDir": "dist",
      "rootDir": "src"
    },
    "include": ["src/tanstack-router/**/*"],
    "exclude": ["node_modules", "dist"]
  }